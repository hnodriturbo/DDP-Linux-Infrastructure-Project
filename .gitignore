# ========================================
# Universal .gitignore
# ========================================
# Purpose:
# - Ignore local dependencies, caches, logs, secrets, build output,
#   IDE settings, temporary files, large files, and machine-specific data.
# - Keep repositories clean, portable, and safe for GitHub uploads.
# ========================================


# ========================================
# Critical Secret Files
# ========================================

**/firebase_admin_service_key.json
**/admin_sdk_service_key.json
**/firebase-admin-sdk.json
firebase_admin_service_key.json
admin_sdk_service_key.json
firebase-admin-sdk.json

*.key
*.pem
*.crt
.secret
secrets.yml


# ========================================
# Environment Files
# ========================================

.env
.env.*
!.env.example
!**/.env.example
env-local
env-production
.env*.local


# ========================================
# Node / Next.js / Frontend
# ========================================

node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

.next/
.nuxt/
out/
dist/
build/
public/build/
coverage/
next-env.d.ts


# ========================================
# Deployment Platforms
# ========================================

.vercel/


# ========================================
# Package Manager Notes
# ========================================
# Lockfiles are intentionally NOT ignored.
# Keep package-lock.json, yarn.lock, pnpm-lock.yaml, and Pipfile.lock tracked
# for reproducible installs.


