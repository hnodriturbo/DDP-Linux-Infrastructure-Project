# ================================
# Local Host Resolution Configuration
# ================================
# Path: /etc/static_hosts
# Purpose:
# - Define local hostname mappings before DNS/BIND9 exists
# - Allow server1, client1, and client2 communication by hostname
# - Keep localhost and IPv6 defaults intact
# ================================


# Loopback interface
127.0.0.1   localhost


# Local system hostname
127.0.1.1   server1.ddp.is server1


# Local DDP infrastructure hosts
192.168.100.10   server1.ddp.is server1
192.168.100.20   client1.ddp.is client1
192.168.100.30   client2.ddp.is client2


# IPv6 localhost entries
::1   ip6-localhost ip6-loopback
fe00::0 ip6-localnet
ff00::0 ip6-mcastprefix
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters